<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows10.0.19041.0</TargetFramework>
    <TargetPlatformVersion>10.0.19041.0</TargetPlatformVersion>
    <SupportedOSPlatformVersion>10.0.17763.0</SupportedOSPlatformVersion>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Kx\Kx.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="Plugins\**" />
    <EmbeddedResource Remove="Plugins\**" />
    <None Remove="Plugins\**" />
    <Content Remove="Plugins\**" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="Assets\**\*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <None Include="Plugins\KxTheme\KxTheme.csproj" />
    <None Include="Plugins\KxTheme\Plugin.yaml" />
    <None Include="Plugins\KxTheme\UI\KalOnline\updater_content.yaml" />
    <None Include="Plugins\KxTheme\UI\KalOnline\updater_frame.yaml" />
  </ItemGroup>

  <Target Name="BuildKxThemePlugin">
    <PropertyGroup>
      <KxThemeProjectDir>$(MSBuildProjectDirectory)\Plugins\KxTheme\</KxThemeProjectDir>
      <KxThemeProjectFile>$(KxThemeProjectDir)KxTheme.csproj</KxThemeProjectFile>
      <KxThemePlatformOutputSegment Condition="'$(Platform)' != '' and '$(Platform)' != 'AnyCPU' and '$(Platform)' != 'Any CPU'">$(Platform)\</KxThemePlatformOutputSegment>
      <KxThemeRuntimeOutputSegment Condition="'$(RuntimeIdentifier)' != ''">$(RuntimeIdentifier)\</KxThemeRuntimeOutputSegment>
    </PropertyGroup>

    <MSBuild Projects="$(KxThemeProjectFile)" Targets="Restore;Build" Properties="Configuration=$(Configuration);Platform=$(Platform);RuntimeIdentifier=$(RuntimeIdentifier);SelfContained=$(SelfContained);TargetFramework=$(TargetFramework)" />
  </Target>

  <Target Name="CopyKxThemeToBuildOutput" AfterTargets="Build" DependsOnTargets="BuildKxThemePlugin">
    <PropertyGroup>
      <KxThemeProjectDir>$(MSBuildProjectDirectory)\Plugins\KxTheme\</KxThemeProjectDir>
      <KxThemePlatformOutputSegment Condition="'$(Platform)' != '' and '$(Platform)' != 'AnyCPU' and '$(Platform)' != 'Any CPU'">$(Platform)\</KxThemePlatformOutputSegment>
      <KxThemeRuntimeOutputSegment Condition="'$(RuntimeIdentifier)' != ''">$(RuntimeIdentifier)\</KxThemeRuntimeOutputSegment>
      <KxThemeOutputDir>$(KxThemeProjectDir)bin\$(KxThemePlatformOutputSegment)$(Configuration)\$(TargetFramework)\$(KxThemeRuntimeOutputSegment)</KxThemeOutputDir>
      <KxThemeTargetDir>$(TargetDir)Assets\Plugins\KxTheme\</KxThemeTargetDir>
      <KxThemeUiTargetDir>$(KxThemeTargetDir)UI\</KxThemeUiTargetDir>
      <KxThemeAssetTargetDir>$(TargetDir)Assets\</KxThemeAssetTargetDir>
    </PropertyGroup>

    <RemoveDir Directories="$(TargetDir)UI" Condition="Exists('$(TargetDir)UI')" />
    <Delete Files="$(TargetDir)Plugin.yaml" Condition="Exists('$(TargetDir)Plugin.yaml')" />

    <MakeDir Directories="$(KxThemeTargetDir);$(KxThemeUiTargetDir);$(KxThemeAssetTargetDir)" />

    <ItemGroup>
      <KxThemeFiles Include="$(KxThemeOutputDir)KxTheme.dll" />
      <KxThemeFiles Include="$(KxThemeOutputDir)KxTheme.pdb" Condition="Exists('$(KxThemeOutputDir)KxTheme.pdb')" />
      <KxThemeFiles Include="$(KxThemeOutputDir)Plugin.yaml" />
      <KxThemeUiFiles Include="$(KxThemeOutputDir)UI\**\*.yaml" />
      <KxThemeAssetFiles Include="$(KxThemeOutputDir)Assets\**\*" />
    </ItemGroup>

    <Copy SourceFiles="@(KxThemeFiles)" DestinationFiles="@(KxThemeFiles->'$(KxThemeTargetDir)%(Filename)%(Extension)')" SkipUnchangedFiles="true" />

    <Copy SourceFiles="@(KxThemeUiFiles)" DestinationFiles="@(KxThemeUiFiles->'$(KxThemeUiTargetDir)%(RecursiveDir)%(Filename)%(Extension)')" SkipUnchangedFiles="true" />

    <Copy SourceFiles="@(KxThemeAssetFiles)" DestinationFiles="@(KxThemeAssetFiles->'$(KxThemeAssetTargetDir)%(RecursiveDir)%(Filename)%(Extension)')" SkipUnchangedFiles="true" />
  </Target>

  <Target Name="CopyKxThemeToPublishOutput" AfterTargets="Publish" DependsOnTargets="BuildKxThemePlugin">
    <PropertyGroup>
      <KxThemeProjectDir>$(MSBuildProjectDirectory)\Plugins\KxTheme\</KxThemeProjectDir>
      <KxThemePlatformOutputSegment Condition="'$(Platform)' != '' and '$(Platform)' != 'AnyCPU' and '$(Platform)' != 'Any CPU'">$(Platform)\</KxThemePlatformOutputSegment>
      <KxThemeRuntimeOutputSegment Condition="'$(RuntimeIdentifier)' != ''">$(RuntimeIdentifier)\</KxThemeRuntimeOutputSegment>
      <KxThemeOutputDir>$(KxThemeProjectDir)bin\$(KxThemePlatformOutputSegment)$(Configuration)\$(TargetFramework)\$(KxThemeRuntimeOutputSegment)</KxThemeOutputDir>
      <KxThemeTargetDir>$(PublishDir)Assets\Plugins\KxTheme\</KxThemeTargetDir>
      <KxThemeUiTargetDir>$(KxThemeTargetDir)UI\</KxThemeUiTargetDir>
      <KxThemeAssetTargetDir>$(PublishDir)Assets\</KxThemeAssetTargetDir>
    </PropertyGroup>

    <RemoveDir Directories="$(PublishDir)UI" Condition="Exists('$(PublishDir)UI')" />
    <Delete Files="$(PublishDir)Plugin.yaml" Condition="Exists('$(PublishDir)Plugin.yaml')" />
    <Delete Files="$(KxThemeTargetDir)KxTheme.deps.json;$(KxThemeTargetDir)Kx.Sdk.dll;$(KxThemeTargetDir)Kx.Sdk.pdb;$(KxThemeTargetDir)Kx.Sdk.xml" Condition="Exists('$(KxThemeTargetDir)KxTheme.deps.json') Or Exists('$(KxThemeTargetDir)Kx.Sdk.dll') Or Exists('$(KxThemeTargetDir)Kx.Sdk.pdb') Or Exists('$(KxThemeTargetDir)Kx.Sdk.xml')" />

    <MakeDir Directories="$(KxThemeTargetDir);$(KxThemeUiTargetDir);$(KxThemeAssetTargetDir)" />

    <ItemGroup>
      <KxThemePublishFiles Include="$(KxThemeOutputDir)KxTheme.dll" />
      <KxThemePublishFiles Include="$(KxThemeOutputDir)Plugin.yaml" />
      <KxThemePublishUiFiles Include="$(KxThemeOutputDir)UI\**\*.yaml" />
      <KxThemePublishAssetFiles Include="$(KxThemeOutputDir)Assets\**\*" />
    </ItemGroup>

    <Copy SourceFiles="@(KxThemePublishFiles)" DestinationFolder="$(KxThemeTargetDir)" SkipUnchangedFiles="true" />

    <Copy SourceFiles="@(KxThemePublishUiFiles)" DestinationFiles="@(KxThemePublishUiFiles->'$(KxThemeUiTargetDir)%(RecursiveDir)%(Filename)%(Extension)')" SkipUnchangedFiles="true" />

    <Copy SourceFiles="@(KxThemePublishAssetFiles)" DestinationFiles="@(KxThemePublishAssetFiles->'$(KxThemeAssetTargetDir)%(RecursiveDir)%(Filename)%(Extension)')" SkipUnchangedFiles="true" />
  </Target>

  <Target Name="RemoveSingleFilePublishSymbols" AfterTargets="Publish" Condition="'$(PublishSingleFile)' == 'true'">
    <ItemGroup>
      <PublishedSymbols Include="$(PublishDir)*.pdb" />
    </ItemGroup>

    <Delete Files="@(PublishedSymbols)" />
  </Target>

</Project>
