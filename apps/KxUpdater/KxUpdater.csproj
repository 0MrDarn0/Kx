<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows10.0.19041.0</TargetFramework>
    <TargetPlatformVersion>10.0.19041.0</TargetPlatformVersion>
    <SupportedOSPlatformVersion>10.0.17763.0</SupportedOSPlatformVersion>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Kx\Kx.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="Plugins\**" />
    <EmbeddedResource Remove="Plugins\**" />
    <None Remove="Plugins\**" />
    <Content Remove="Plugins\**" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="Assets\**\*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <Target Name="BuildKalThemePlugin">
    <PropertyGroup>
      <KalThemeProjectDir>$(MSBuildProjectDirectory)\Plugins\KalTheme\</KalThemeProjectDir>
      <KalThemeProjectFile>$(KalThemeProjectDir)KalTheme.csproj</KalThemeProjectFile>
    </PropertyGroup>

    <MSBuild Projects="$(KalThemeProjectFile)"
             Targets="Build"
             Properties="Configuration=$(Configuration);TargetFramework=$(TargetFramework)" />
  </Target>

  <Target Name="CopyKalThemeToBuildOutput" AfterTargets="Build" DependsOnTargets="BuildKalThemePlugin">
    <PropertyGroup>
      <KalThemeProjectDir>$(MSBuildProjectDirectory)\Plugins\KalTheme\</KalThemeProjectDir>
      <KalThemeOutputDir>$(KalThemeProjectDir)bin\$(Configuration)\$(TargetFramework)\</KalThemeOutputDir>
      <KalThemeTargetDir>$(TargetDir)Assets\Plugins\KalTheme\</KalThemeTargetDir>
      <KalThemeUiTargetDir>$(KalThemeTargetDir)UI\</KalThemeUiTargetDir>
      <KalThemeAssetTargetDir>$(TargetDir)Assets\</KalThemeAssetTargetDir>
    </PropertyGroup>

    <RemoveDir Directories="$(TargetDir)UI" Condition="Exists('$(TargetDir)UI')" />
    <Delete Files="$(TargetDir)Plugin.yaml" Condition="Exists('$(TargetDir)Plugin.yaml')" />

    <MakeDir Directories="$(KalThemeTargetDir);$(KalThemeUiTargetDir);$(KalThemeAssetTargetDir)" />

    <ItemGroup>
      <KalThemeFiles Include="$(KalThemeOutputDir)KalTheme.dll" />
      <KalThemeFiles Include="$(KalThemeOutputDir)KalTheme.pdb" Condition="Exists('$(KalThemeOutputDir)KalTheme.pdb')" />
      <KalThemeFiles Include="$(KalThemeOutputDir)Plugin.yaml" />
      <KalThemeUiFiles Include="$(KalThemeOutputDir)UI\**\*.yaml" />
      <KalThemeAssetFiles Include="$(KalThemeOutputDir)Assets\**\*" />
    </ItemGroup>

    <Copy SourceFiles="@(KalThemeFiles)"
          DestinationFiles="@(KalThemeFiles->'$(KalThemeTargetDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />

    <Copy SourceFiles="@(KalThemeUiFiles)"
          DestinationFiles="@(KalThemeUiFiles->'$(KalThemeUiTargetDir)%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />

    <Copy SourceFiles="@(KalThemeAssetFiles)"
          DestinationFiles="@(KalThemeAssetFiles->'$(KalThemeAssetTargetDir)%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />
  </Target>

  <Target Name="CopyKalThemeToPublishOutput" AfterTargets="Publish" DependsOnTargets="BuildKalThemePlugin">
    <PropertyGroup>
      <KalThemeProjectDir>$(MSBuildProjectDirectory)\Plugins\KalTheme\</KalThemeProjectDir>
      <KalThemeOutputDir>$(KalThemeProjectDir)bin\$(Configuration)\$(TargetFramework)\</KalThemeOutputDir>
      <KalThemeTargetDir>$(PublishDir)Assets\Plugins\KalTheme\</KalThemeTargetDir>
      <KalThemeUiTargetDir>$(KalThemeTargetDir)UI\</KalThemeUiTargetDir>
      <KalThemeAssetTargetDir>$(PublishDir)Assets\</KalThemeAssetTargetDir>
    </PropertyGroup>

    <RemoveDir Directories="$(PublishDir)UI" Condition="Exists('$(PublishDir)UI')" />
    <Delete Files="$(PublishDir)Plugin.yaml" Condition="Exists('$(PublishDir)Plugin.yaml')" />

    <MakeDir Directories="$(KalThemeTargetDir);$(KalThemeUiTargetDir);$(KalThemeAssetTargetDir)" />

    <ItemGroup>
      <KalThemePublishFiles Include="$(KalThemeOutputDir)*.*"
                            Exclude="$(KalThemeOutputDir)UI\**\*;$(KalThemeOutputDir)Assets\**\*;$(KalThemeOutputDir)*.pdb" />
      <KalThemePublishUiFiles Include="$(KalThemeOutputDir)UI\**\*.yaml" />
      <KalThemePublishAssetFiles Include="$(KalThemeOutputDir)Assets\**\*" />
    </ItemGroup>

    <Copy SourceFiles="@(KalThemePublishFiles)"
          DestinationFolder="$(KalThemeTargetDir)"
          SkipUnchangedFiles="true" />

    <Copy SourceFiles="@(KalThemePublishUiFiles)"
          DestinationFiles="@(KalThemePublishUiFiles->'$(KalThemeUiTargetDir)%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />

    <Copy SourceFiles="@(KalThemePublishAssetFiles)"
          DestinationFiles="@(KalThemePublishAssetFiles->'$(KalThemeAssetTargetDir)%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />
  </Target>

</Project>
